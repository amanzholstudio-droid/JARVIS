<Window x:Class="JARVIS.MatrixCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сверить по матрице" Height="600" Width="560"
        Background="#0F172A" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Slate950" Color="#020617"/>
        <SolidColorBrush x:Key="Slate900" Color="#0F172A"/>
        <SolidColorBrush x:Key="Slate800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Slate400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Slate200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Blue500" Color="#3B82F6"/>
        <SolidColorBrush x:Key="Emerald500" Color="#10B981"/>
        <SolidColorBrush x:Key="Rose500" Color="#F43F5E"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Slate950}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate200}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Slate800}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Поиск ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TbSearch" Grid.Column="0" Margin="0,0,8,0"
                     KeyDown="TbSearch_KeyDown"/>
            <Button Grid.Column="1" Content="Найти" Click="Search_Click"
                    Background="{StaticResource Blue500}" Foreground="White"
                    FontWeight="SemiBold" Padding="16,0" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <TextBlock x:Name="TbStatus" Grid.Row="1" Foreground="{StaticResource Slate400}"
                   FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <!-- ===== Результаты ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Slate950}" BorderBrush="{StaticResource Slate800}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Position}" Foreground="{StaticResource Emerald500}"
                                           FontWeight="Bold" FontSize="13" Margin="0,0,0,2"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource Slate400}" Margin="0,0,0,10">
                                    <Run Text="{Binding Department}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Division}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Location}"/>
                                </TextBlock>

                                <TextBlock Text="Действующие характеристики" Foreground="{StaticResource Blue500}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="{StaticResource Slate200}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap">
                                    <Run Text="{Binding CurrentType}"/><Run Text=" · ЦП: "/><Run Text="{Binding CurrentCpu}"/>
                                    <LineBreak/>
                                    <Run Text="ОЗУ: "/><Run Text="{Binding CurrentRam}"/><Run Text=" · SSD: "/><Run Text="{Binding CurrentSsd}"/>
                                    <Run Text=" · HDD: "/><Run Text="{Binding CurrentHdd}"/>
                                    <LineBreak/>
                                    <Run Text="Видеокарта: "/><Run Text="{Binding CurrentGpu}"/>
                                </TextBlock>

                                <TextBlock Text="Характеристики (актуальные)" Foreground="{StaticResource Blue500}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="{StaticResource Slate200}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap">
                                    <Run Text="{Binding TargetType}"/><Run Text=" · ЦП: "/><Run Text="{Binding TargetCpu}"/>
                                    <LineBreak/>
                                    <Run Text="ОЗУ: "/><Run Text="{Binding TargetRam}"/><Run Text=" · SSD: "/><Run Text="{Binding TargetSsd}"/>
                                    <Run Text=" · HDD: "/><Run Text="{Binding TargetHdd}"/>
                                    <LineBreak/>
                                    <Run Text="Видеокарта: "/><Run Text="{Binding TargetGpu}"/>
                                </TextBlock>

                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <Run Text="Монитор: " Foreground="{StaticResource Slate400}"/>
                                    <Run Text="{Binding MonitorDisplay, Mode=OneWay}" Foreground="{StaticResource Slate200}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
