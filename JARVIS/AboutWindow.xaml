<Window x:Class="JARVIS.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Об авторе" Width="480" SizeToContent="Height"
        Background="#0F172A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Slate400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Slate200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Blue400" Color="#60A5FA"/>
    </Window.Resources>

    <StackPanel Margin="24">
        <Image x:Name="LogoImage" Width="96" Height="96" Margin="0,0,0,16" Stretch="Uniform"/>

        <TextBlock Text="Аманжолов Мәди Қайратұлы" Foreground="{StaticResource Slate200}"
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Text="Разработчик J.A.R.V.I.S" Foreground="{StaticResource Slate400}"
                   FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                <Hyperlink NavigateUri="mailto:amanzholovstudio@gmail.com" Click="Email_Click"
                           Foreground="{StaticResource Blue400}">
                    amanzholovstudio@gmail.com
                </Hyperlink>
            </TextBlock>
            <TextBlock Text="+7 706 648 6698" Foreground="{StaticResource Slate400}"
                       FontSize="12" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1"
                CornerRadius="8" Padding="16">
            <TextBlock Foreground="{StaticResource Slate400}" FontStyle="Italic" FontSize="11.5"
                       TextWrapping="Wrap" LineHeight="18">
                «Говорят, лучшее оружие против бюрократии — это регламенты. Я с этим категорически не согласен. Я считаю, лучшее оружие — то, которое уничтожает рутину всего за один клик. Мой отец так делал, Казахстан так делает, и это неплохо работает.
                <LineBreak/><LineBreak/>
                Представляю вам флагман ИТ-обороны от Amanzhol Индастриз. Это первая десктопная система, использующая нашу фирменную технологию разделяющихся боеголовок Open XML и автоматического трекинга в Excel. Говорят, от бесконечной текучки кадров и потерянной истории не уйдёшь. Ну, теперь точно не уйдёшь.
                <LineBreak/><LineBreak/>
                Достаточно одного такого залпа, и косяки с выдачей техники даже не захотят вылезать из своих пещер. Прошу любить и жаловать — "Джарвис"».
            </TextBlock>
        </Border>
    </StackPanel>
</Window>
