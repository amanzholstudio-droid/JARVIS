<Window x:Class="JARVIS.EmailRecipientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Получатели письма" Width="420" SizeToContent="Height"
        Background="#0F172A" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Этот список подставляется в поля &quot;Кому&quot;/&quot;Копия&quot; каждый раз при отправке письма — вводить руками больше не нужно. Несколько адресов разделяй точкой с запятой ( ; )."
                   Foreground="#64748B" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock Text="Кому" Style="{StaticResource Label}"/>
        <TextBox x:Name="TbTo" AcceptsReturn="False" TextWrapping="Wrap"/>

        <TextBlock Text="Копия" Style="{StaticResource Label}"/>
        <TextBox x:Name="TbCc" AcceptsReturn="False" TextWrapping="Wrap"/>

        <Button Content="Сохранить" Click="Save_Click" Margin="0,10,0,0"
                Background="#3B82F6" Foreground="White" FontWeight="SemiBold"
                Padding="0,10" BorderThickness="0" Cursor="Hand"/>
    </StackPanel>
</Window>
